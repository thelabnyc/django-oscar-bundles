{
    "compilerOptions": {
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "alwaysStrict": true,
        "declaration": false,
        "declarationMap": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "importHelpers": true,
        "inlineSources": false,
        "jsx": "react",
        "lib": ["es6", "es2017", "es2015.collection", "es2015.iterable", "dom"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "newLine": "lf",
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "./build/",
        "preserveConstEnums": true,
        "pretty": true,
        "removeComments": false,
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": true,
        "target": "es6",
        "types": ["jest"]
    }
}
